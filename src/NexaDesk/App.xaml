<Application
    x:Class="NexaDesk.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <!--
              WinUI control templates require XamlControlsResources. The custom
              Program.Main must call XamlCheckProcessRequirements before App is
              constructed so this dictionary can resolve its theme PRI assets in
              unpackaged, self-contained deployments.
            -->
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="NexaWindowBrush" Color="#FFF6F8FA" />
                    <SolidColorBrush x:Key="NexaSidebarBrush" Color="#F2FFFFFF" />
                    <SolidColorBrush x:Key="NexaCardBrush" Color="#F7FFFFFF" />
                    <SolidColorBrush x:Key="NexaSubtleBrush" Color="#11000000" />
                    <SolidColorBrush x:Key="NexaNavSelectedBrush" Color="#180067C0" />
                    <SolidColorBrush x:Key="NexaAccentBrush" Color="#FF0067C0" />
                    <SolidColorBrush x:Key="NexaAccentForegroundBrush" Color="#FFFFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="NexaWindowBrush" Color="#FF202020" />
                    <SolidColorBrush x:Key="NexaSidebarBrush" Color="#EE181818" />
                    <SolidColorBrush x:Key="NexaCardBrush" Color="#D81F1F1F" />
                    <SolidColorBrush x:Key="NexaSubtleBrush" Color="#18FFFFFF" />
                    <SolidColorBrush x:Key="NexaNavSelectedBrush" Color="#2860CDFF" />
                    <SolidColorBrush x:Key="NexaAccentBrush" Color="#FF60CDFF" />
                    <SolidColorBrush x:Key="NexaAccentForegroundBrush" Color="#FF102028" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource NexaAccentBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource NexaAccentForegroundBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,8" />
            </Style>
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource NexaSubtleBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="14,7" />
            </Style>
            <Style x:Key="NavigationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>