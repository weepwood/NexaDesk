<Window
    x:Class="NexaDesk.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Background="{ThemeResource NexaWindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="14,0"
            Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE945;" FontSize="16" />
                <TextBlock Text="NexaDesk" FontWeight="SemiBold" />
                <Border Padding="8,2" Background="{ThemeResource NexaSubtleBrush}" CornerRadius="10">
                    <TextBlock Text="LOCAL" FontSize="10" FontWeight="SemiBold" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid x:Name="NavigationShell" Grid.Row="1" IsEnabled="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{ThemeResource NexaSidebarBrush}"
                BorderBrush="{ThemeResource NexaSubtleBrush}"
                BorderThickness="0,0,1,0">
                <Grid Padding="10,12,10,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <Button
                            x:Name="HomeNavigationButton"
                            Tag="home"
                            Style="{StaticResource NavigationButtonStyle}"
                            Click="OnNavigationButtonClicked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE80F;" FontSize="17" />
                                <TextBlock Text="首页" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="ActionsNavigationButton"
                            Tag="actions"
                            Style="{StaticResource NavigationButtonStyle}"
                            Click="OnNavigationButtonClicked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE945;" FontSize="17" />
                                <TextBlock Text="动作" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="WorkflowsNavigationButton"
                            Tag="workflows"
                            Style="{StaticResource NavigationButtonStyle}"
                            Click="OnNavigationButtonClicked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE8F1;" FontSize="17" />
                                <TextBlock Text="工作流" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="HistoryNavigationButton"
                            Tag="history"
                            Style="{StaticResource NavigationButtonStyle}"
                            Click="OnNavigationButtonClicked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE81C;" FontSize="17" />
                                <TextBlock Text="历史记录" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Border Height="1" Margin="8,7" Background="{ThemeResource NexaSubtleBrush}" />
                        <Button
                            x:Name="SettingsNavigationButton"
                            Tag="settings"
                            Style="{StaticResource NavigationButtonStyle}"
                            Click="OnNavigationButtonClicked">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE713;" FontSize="17" />
                                <TextBlock Text="设置" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border
                        Grid.Row="2"
                        Margin="2,12,2,0"
                        Padding="12"
                        CornerRadius="10"
                        Background="{ThemeResource NexaSubtleBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="命令面板" FontWeight="SemiBold" />
                            <TextBlock Text="Ctrl + Alt + Space" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Column="1" />
        </Grid>

        <Grid
            x:Name="StartupOverlay"
            Grid.Row="1"
            Background="{ThemeResource NexaWindowBrush}">
            <Border
                Width="560"
                Padding="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource NexaCardBrush}"
                CornerRadius="18">
                <StackPanel Spacing="16">
                    <ProgressRing
                        x:Name="StartupProgress"
                        Width="42"
                        Height="42"
                        IsActive="True"
                        HorizontalAlignment="Left" />
                    <TextBlock
                        x:Name="StartupTitle"
                        Text="正在启动 NexaDesk"
                        FontSize="26"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="StartupMessage"
                        Text="正在准备本地数据和 Windows 集成功能…"
                        TextWrapping="Wrap"
                        Opacity="0.75" />
                    <TextBlock
                        x:Name="StartupDetails"
                        Visibility="Collapsed"
                        TextWrapping="Wrap"
                        FontFamily="Consolas"
                        FontSize="12"
                        Opacity="0.72" />
                    <StackPanel
                        x:Name="StartupActions"
                        Visibility="Collapsed"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            Content="打开日志目录"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnOpenLogFolderClicked" />
                        <Button
                            Content="退出"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnExitClicked" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>