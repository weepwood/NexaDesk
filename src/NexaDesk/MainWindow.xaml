<Window
    x:Class="NexaDesk.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="14,0"
            Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE945;" FontSize="16" />
                <TextBlock Text="NexaDesk" FontWeight="SemiBold" />
                <Border Padding="8,2" Background="{ThemeResource NexaSubtleBrush}" CornerRadius="10">
                    <TextBlock Text="LOCAL" FontSize="10" FontWeight="SemiBold" />
                </Border>
            </StackPanel>
        </Grid>

        <NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            IsEnabled="False"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            CompactPaneLength="48"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="首页" Tag="home">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="动作" Tag="actions">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE945;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="工作流" Tag="workflows">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F1;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="历史记录" Tag="history">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE81C;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="设置" Tag="settings">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.PaneFooter>
                <Border Margin="8" Padding="12" CornerRadius="10" Background="{ThemeResource NexaSubtleBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="命令面板" FontWeight="SemiBold" />
                        <TextBlock Text="Ctrl + Alt + Space" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Grid
            x:Name="StartupOverlay"
            Grid.Row="1"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Border
                Width="560"
                Padding="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource NexaCardBrush}"
                CornerRadius="18">
                <StackPanel Spacing="16">
                    <ProgressRing
                        x:Name="StartupProgress"
                        Width="42"
                        Height="42"
                        IsActive="True"
                        HorizontalAlignment="Left" />
                    <TextBlock
                        x:Name="StartupTitle"
                        Text="正在启动 NexaDesk"
                        FontSize="26"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="StartupMessage"
                        Text="正在准备本地数据和 Windows 集成功能…"
                        TextWrapping="Wrap"
                        Opacity="0.75" />
                    <TextBlock
                        x:Name="StartupDetails"
                        Visibility="Collapsed"
                        TextWrapping="Wrap"
                        FontFamily="Consolas"
                        FontSize="12"
                        Opacity="0.72" />
                    <StackPanel
                        x:Name="StartupActions"
                        Visibility="Collapsed"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            Content="打开日志目录"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnOpenLogFolderClicked" />
                        <Button
                            Content="退出"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnExitClicked" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
