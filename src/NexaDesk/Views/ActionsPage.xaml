<Page
    x:Class="NexaDesk.Views.ActionsPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="32,24,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="5">
            <TextBlock Text="动作" FontSize="30" FontWeight="SemiBold" />
            <TextBlock Text="内置 Windows 动作和开始菜单应用索引。" Opacity="0.7" />
        </StackPanel>

        <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,18,0,14"
                 PlaceholderText="搜索名称、分类或描述"
                 TextChanged="OnSearchTextChanged" />

        <ListView Grid.Row="2" ItemsSource="{Binding Actions}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="6,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{Binding IconGlyph}" FontSize="22" />
                        <StackPanel Grid.Column="1" Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <Border Padding="7,2" Background="{ThemeResource NexaSubtleBrush}"
                                        CornerRadius="8">
                                    <TextBlock Text="{Binding Category}" FontSize="11" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" Opacity="0.65"
                                       FontSize="12" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Margin="8,0" Content="收藏"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=Root}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="3" Content="运行"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding DataContext.RunActionCommand, ElementName=Root}"
                                CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="3" Margin="0,12,0,0"
                   Text="{Binding StatusMessage}" Opacity="0.7" />
    </Grid>
</Page>
