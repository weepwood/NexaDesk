<Page
    x:Class="NexaDesk.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="32,24,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="5">
            <TextBlock Text="历史记录" FontSize="30" FontWeight="SemiBold" />
            <TextBlock Text="执行记录只保存在本机 SQLite 数据库中。" Opacity="0.7" />
        </StackPanel>

        <ListView Grid.Row="1" Margin="0,18,0,0"
                  ItemsSource="{Binding Items}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="6,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="190" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="{Binding ActionName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Message}" Opacity="0.65" FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding ExecutedAt}" Opacity="0.65"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
