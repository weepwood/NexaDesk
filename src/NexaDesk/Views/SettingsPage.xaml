<Page
    x:Class="NexaDesk.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32,24,32,40" Spacing="18">
            <StackPanel Spacing="5">
                <TextBlock Text="设置" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="所有设置和交互数据均保存在本机。" Opacity="0.7" />
            </StackPanel>

            <Border Padding="18" CornerRadius="14" Background="{ThemeResource NexaCardBrush}">
                <StackPanel Spacing="16">
                    <TextBlock Text="外观与启动" FontSize="18" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="主题" FontWeight="SemiBold" />
                            <TextBlock Text="支持跟随 Windows、浅色和深色。" Opacity="0.65" FontSize="12" />
                        </StackPanel>
                        <ComboBox x:Name="ThemeBox" Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnThemeChanged">
                            <ComboBoxItem Content="跟随系统" Tag="System" />
                            <ComboBoxItem Content="浅色" Tag="Light" />
                            <ComboBoxItem Content="深色" Tag="Dark" />
                        </ComboBox>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="开机启动" FontWeight="SemiBold" />
                            <TextBlock Text="仅 MSIX 安装版支持系统启动任务。" Opacity="0.65" FontSize="12" />
                        </StackPanel>
                        <ToggleSwitch x:Name="StartupToggle" Grid.Column="1"
                                      IsEnabled="{Binding StartupSupported}"
                                      Toggled="OnStartupToggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="18" CornerRadius="14" Background="{ThemeResource NexaCardBrush}">
                <StackPanel Spacing="14">
                    <TextBlock Text="更新" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock
                        Text="MSIX 安装版由 App Installer 检查更新；便携版检查 GitHub Release。"
                        Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="检查更新" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CheckUpdatesCommand}" />
                        <Button Content="打开发布页面" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenReleasePageCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="18" CornerRadius="14" Background="{ThemeResource NexaCardBrush}">
                <StackPanel Spacing="14">
                    <TextBlock Text="本地数据" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="打开数据目录" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenDataFolderCommand}" />
                        <Button Content="重新扫描应用" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RescanApplicationsCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Opacity="0.75" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
