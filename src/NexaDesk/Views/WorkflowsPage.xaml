<Page
    x:Class="NexaDesk.Views.WorkflowsPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="32,24,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="5">
                <TextBlock Text="工作流" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="按顺序组合本地动作，不需要后端服务。" Opacity="0.7" />
            </StackPanel>
            <Button Grid.Column="1" Content="新建工作流"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnCreateWorkflowClicked" />
        </Grid>

        <ListView Grid.Row="1" Margin="0,18,0,0"
                  ItemsSource="{Binding Workflows}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="16" CornerRadius="12"
                            Background="{ThemeResource NexaCardBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}" Opacity="0.65" />
                                <TextBlock Text="{Binding StepCountText}" FontSize="12" Opacity="0.65" />
                            </StackPanel>
                            <Button Grid.Column="1" Margin="8,0" Content="删除"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DataContext.DeleteWorkflowCommand, ElementName=Root}"
                                    CommandParameter="{Binding}" />
                            <Button Grid.Column="2" Content="运行"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DataContext.RunWorkflowCommand, ElementName=Root}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2" Margin="0,12,0,0"
                   Text="{Binding StatusMessage}" Opacity="0.7" />
    </Grid>
</Page>
